# This lab reads keys from the SHARED Ironhack env file:
#   ~/.config/ironhack/.env.local   (mode 600, outside every git repo)
#
# A local .env here is optional and overrides the shared file.
# Never put real keys in this example file.

COHERE_API_KEY=
OPENAI_API_KEY=
NEWS_API_KEY=

ENVIRONMENT=development
MAX_RETRIES=3
REQUEST_TIMEOUT=30
DAILY_BUDGET=5.00
